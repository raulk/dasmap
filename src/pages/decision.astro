---
import Base from '../layouts/Base.astro';
import DecisionView from '../islands/DecisionView';
import { BASE } from '../lib/base';
---

<Base title="Decision" description="Decision tree for choosing DAS building blocks" wide>
  <div class="space-y-4">
    <div class="animate-in">
      <nav class="text-[11px] font-mono mb-3" style="color: var(--c-text-3);">
        <a href={`${BASE}/`} class="hover:underline underline-offset-2">dasmap</a>
        <span class="mx-1">/</span>
        <span style="color: var(--c-text-2);">decision</span>
      </nav>
      <h1 class="text-2xl font-semibold tracking-tight">Decision tree</h1>
      <p class="text-[14px] mt-1" style="color: var(--c-text-2);">Start from your binding constraint and find the relevant atoms.</p>
    </div>
    <div class="animate-in animate-in-delay-1 rounded overflow-hidden" style="border: 1px solid var(--c-border);">
      <DecisionView client:load />
    </div>
  </div>
</Base>
