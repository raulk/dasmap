---
import Base from '../layouts/Base.astro';
import AtomPill from '../components/AtomPill.astro';
import { ATOMS } from '../data/atoms';
import { CATEGORIES } from '../data/categories';
import { EDGES } from '../data/edges';
import { COMPOSITES } from '../data/composites';
import { PROPERTIES } from '../data/properties';

const layerGroups: Record<number, string[]> = {};
for (const [catId, cat] of Object.entries(CATEGORIES)) {
  if (!layerGroups[cat.layer]) layerGroups[cat.layer] = [];
  layerGroups[cat.layer].push(catId);
}
const sortedLayers = Object.keys(layerGroups).map(Number).sort((a, b) => a - b);

const atomsByCategory: Record<string, typeof ATOMS> = {};
for (const atom of ATOMS) {
  if (!atomsByCategory[atom.cat]) atomsByCategory[atom.cat] = [];
  atomsByCategory[atom.cat].push(atom);
}
---

<Base>
  <!-- Hero -->
  <section class="pt-6 pb-16 animate-in">
    <div class="flex items-baseline gap-6 mb-4">
      <h1 class="font-mono font-bold text-[42px] tracking-[-0.04em] leading-none" style="color: var(--c-text);">
        dasmap
      </h1>
      <div class="flex gap-8 font-mono text-sm" style="color: var(--c-text-3);">
        <span><span class="font-semibold text-lg" style="color: var(--c-text);">{ATOMS.length}</span> atoms</span>
        <span><span class="font-semibold text-lg" style="color: var(--c-text);">{PROPERTIES.length}</span> properties</span>
        <span><span class="font-semibold text-lg" style="color: var(--c-text);">{COMPOSITES.length}</span> composites</span>
        <span><span class="font-semibold text-lg" style="color: var(--c-text);">{EDGES.length}</span> edges</span>
      </div>
    </div>
    <p class="text-[15px] max-w-xl leading-relaxed" style="color: var(--c-text-2);">
      A structured map of Ethereum's data availability sampling design space:
      atomic building blocks, their properties, relationships, and how they compose into full protocol proposals.
    </p>
  </section>

  <!-- Architecture layers -->
  <section class="animate-in animate-in-delay-1">
    <h2
      class="text-[11px] font-semibold uppercase tracking-[0.08em] mb-4"
      style="color: var(--c-text-3);"
    >
      Architecture layers
    </h2>
    <div class="space-y-px">
      {sortedLayers.map((layer) => {
        const catIds = layerGroups[layer];
        const layerAtoms = catIds.flatMap(catId => atomsByCategory[catId] ?? []);
        const primaryCatId = catIds[0];
        const primaryCat = CATEGORIES[primaryCatId as keyof typeof CATEGORIES];

        return (
          <div
            class="flex items-start gap-0"
            style={{
              borderLeft: `2px solid ${primaryCat.color}`,
              background: `${primaryCat.color}06`,
            }}
          >
            <div class="w-48 shrink-0 px-4 py-3 flex flex-col justify-center self-stretch">
              <div class="font-mono text-[10px] font-medium mb-0.5" style="color: var(--c-text-3);">L{layer}</div>
              <div class="text-[11px] font-semibold leading-tight" style={{ color: primaryCat.color }}>
                {catIds.map((id, i) => (
                  <span>
                    <span class="font-mono">{id}</span>
                    {' '}
                    {CATEGORIES[id as keyof typeof CATEGORIES].name}
                    {i < catIds.length - 1 && <br />}
                  </span>
                ))}
              </div>
            </div>
            <div class="flex-1 px-3 py-2.5 flex flex-wrap gap-1.5 items-center">
              {layerAtoms.map(atom => (
                <AtomPill
                  id={atom.id}
                  name={atom.name}
                  cat={atom.cat}
                  maturity={atom.maturity}
                  href={`/atoms/${atom.id.toLowerCase()}`}
                />
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Categories -->
  <section class="mt-12 animate-in animate-in-delay-2">
    <h2
      class="text-[11px] font-semibold uppercase tracking-[0.08em] mb-4"
      style="color: var(--c-text-3);"
    >
      Categories
    </h2>
    <div class="flex flex-wrap gap-x-6 gap-y-2">
      {(Object.entries(CATEGORIES) as [string, typeof CATEGORIES[keyof typeof CATEGORIES]][]).map(([id, cat]) => (
        <div class="flex items-center gap-2 text-[12px]">
          <span
            class="w-5 h-5 rounded flex items-center justify-center font-mono font-semibold text-[10px]"
            style={{ background: `${cat.color}18`, color: cat.color }}
          >
            {id}
          </span>
          <span class="font-medium" style={{ color: cat.color }}>
            {cat.name}
          </span>
        </div>
      ))}
    </div>
  </section>
</Base>
