---
import Base from '../layouts/Base.astro';
import GraphView from '../islands/GraphView';
---

<Base title="Graph" description="Dependency graph of all DAS atoms" wide>
  <div class="space-y-4">
    <div class="animate-in">
      <nav class="text-[11px] font-mono mb-3" style="color: var(--c-text-3);">
        <a href="/" class="hover:underline underline-offset-2">dasmap</a>
        <span class="mx-1">/</span>
        <span style="color: var(--c-text-2);">graph</span>
      </nav>
      <h1 class="text-2xl font-semibold tracking-tight">Dependency graph</h1>
      <p class="text-[14px] mt-1" style="color: var(--c-text-2);">Force-directed layout of atom relationships. Click a node to inspect.</p>
    </div>
    <div class="animate-in animate-in-delay-1">
      <GraphView client:load />
    </div>
  </div>
</Base>
