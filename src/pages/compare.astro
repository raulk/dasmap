---
import Base from '../layouts/Base.astro';
import CompareView from '../islands/CompareView';
import { BASE } from '../lib/base';
---

<Base title="Compare" description="Compare atom membership across composite proposals" wide>
  <div class="space-y-4">
    <div class="animate-in">
      <nav class="text-[11px] font-mono mb-3" style="color: var(--c-text-3);">
        <a href={`${BASE}/`} class="hover:underline underline-offset-2">dasmap</a>
        <span class="mx-1">/</span>
        <span style="color: var(--c-text-2);">compare</span>
      </nav>
      <h1 class="text-2xl font-semibold tracking-tight">Composite comparison</h1>
      <p class="text-[14px] mt-1" style="color: var(--c-text-2);">Which atoms each composite proposal includes. Click rows or columns to navigate.</p>
    </div>
    <div class="animate-in animate-in-delay-1">
      <CompareView client:load />
    </div>
  </div>
</Base>
