---
const pathname = Astro.url.pathname;

const links = [
  { href: '/atoms',      label: 'Atoms' },
  { href: '/properties', label: 'Properties' },
  { href: '/graph',      label: 'Graph' },
  { href: '/matrix',     label: 'Matrix' },
  { href: '/compare',    label: 'Compare' },
  { href: '/decision',   label: 'Decision' },
  { href: '/timeline',   label: 'Timeline' },
];

function isActive(href: string): boolean {
  return pathname === href || pathname.startsWith(href + '/');
}
---

<header style="background: var(--c-nav);">
  <div class="mx-auto max-w-screen-xl px-6 h-11 flex items-center gap-8">
    <a
      href="/"
      class="font-mono font-bold text-sm tracking-tight shrink-0"
      style="color: var(--c-nav-active); letter-spacing: -0.03em;"
    >
      dasmap
    </a>
    <nav class="flex items-center gap-1 overflow-x-auto no-scrollbar">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class="px-2.5 py-1 text-[13px] font-medium whitespace-nowrap transition-colors"
          style={{
            color: isActive(href) ? 'var(--c-nav-active)' : 'var(--c-nav-text)',
            borderBottom: isActive(href) ? '1.5px solid var(--c-nav-active)' : '1.5px solid transparent',
          }}
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>
