---
import { MATURITY_LABELS } from '../data/maturity';

interface Props {
  maturity: number;
}

const { maturity } = Astro.props;
const label = MATURITY_LABELS[maturity as 1|2|3|4|5];
---

<span
  class="inline-flex items-center text-[11px] font-medium px-2 py-0.5 rounded"
  style="background: var(--c-surface-dim); color: var(--c-text-2); border: 1px solid var(--c-border);"
>
  Stage: {label}
</span>
