---
import { CATEGORIES } from '../data/categories';

interface Props {
  cat: string;
}

const { cat } = Astro.props;
const category = CATEGORIES[cat as keyof typeof CATEGORIES];
---

<span
  class="inline-flex items-center gap-1 text-[11px] font-medium px-2 py-0.5 rounded"
  style="background: var(--c-surface-dim); color: var(--c-text-2); border: 1px solid var(--c-border);"
>
  <span class="font-mono font-semibold" style={{ color: category.color }}>{cat}</span>
  {category.name}
</span>
