---
import { CATEGORIES } from '../data/categories';

interface Props {
  cat: string;
}

const { cat } = Astro.props;
const category = CATEGORIES[cat as keyof typeof CATEGORIES];
---

<span
  class="inline-flex items-center text-[11px] font-semibold px-2 py-0.5 rounded"
  style={{ background: `${category.color}10`, color: category.color, border: `1px solid ${category.color}22` }}
>
  <span class="font-mono mr-1">{cat}</span>{category.name}
</span>
