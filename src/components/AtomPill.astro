---
import { CATEGORIES } from '../data/categories';

interface Props {
  id: string;
  name: string;
  cat: string;
  maturity: number;
  href?: string;
}

const { id, name, cat, href } = Astro.props;
const category = CATEGORIES[cat as keyof typeof CATEGORIES];
---

{href ? (
  <a
    href={href}
    class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded text-xs font-medium transition-opacity hover:opacity-75"
    style="background: var(--c-surface-dim); color: var(--c-text-2); border: 1px solid var(--c-border);"
  >
    <span class="font-mono text-[11px] font-semibold" style={{ color: category.color }}>{id}</span>
    <span class="max-w-48 truncate">{name}</span>
  </a>
) : (
  <span
    class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded text-xs font-medium"
    style="background: var(--c-surface-dim); color: var(--c-text-2); border: 1px solid var(--c-border);"
  >
    <span class="font-mono text-[11px] font-semibold" style={{ color: category.color }}>{id}</span>
    <span class="max-w-48 truncate">{name}</span>
  </span>
)}
